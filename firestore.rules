rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the authenticated user owns the document/profile
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Checks if the user is a member of the requested workspace
    // Note: For basic Phase 1, we match workspaceId with the user's uid.
    // In Phase 2, this will check the user's active workspace memberships collection.
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && (workspaceId == request.auth.uid);
    }

    // --- COLLECTION RULES ---

    // 1. Users Profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 2. Budgets configurations
    match /budgets/{budgetId} {
      allow read, write: if isAuthenticated() && 
        (resource == null || isWorkspaceMember(resource.data.workspaceId)) &&
        (request.resource == null || isWorkspaceMember(request.resource.data.workspaceId));
    }

    // 3. Transactions / Expenses Logs
    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || isWorkspaceMember(resource.data.workspaceId)) &&
        (request.resource == null || isWorkspaceMember(request.resource.data.workspaceId));
    }

    // 4. Todo Tasks
    match /todos/{todoId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || isWorkspaceMember(resource.data.workspaceId)) &&
        (request.resource == null || isWorkspaceMember(request.resource.data.workspaceId));
    }

    // 5. Savings Goals
    match /savingsGoals/{goalId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || isWorkspaceMember(resource.data.workspaceId)) &&
        (request.resource == null || isWorkspaceMember(request.resource.data.workspaceId));
    }

    // 6. Income Records
    match /income_records/{recordId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || isWorkspaceMember(resource.data.workspaceId)) &&
        (request.resource == null || isWorkspaceMember(request.resource.data.workspaceId));
    }


    // 6. Categories Customizations
    match /categories/{categoryId} {
      // Allow read if user is authenticated and is either the creator or category is system-wide
      allow read: if isAuthenticated() && 
        (resource.data.scope == "workspace" && isWorkspaceMember(resource.data.workspaceId) ||
         resource.data.scope == "personal" && resource.data.ownerUserId == request.auth.uid ||
         resource.data.ownerUserId == "system");

      // Allow create only if authenticated user is setting themselves as the creator/owner
      allow create: if isAuthenticated() &&
        request.resource.data.ownerUserId == request.auth.uid &&
        (request.resource.data.scope == "personal" || isWorkspaceMember(request.resource.data.workspaceId));

      // Allow update only if authenticated user is the owner and maintains ownership
      allow update: if isAuthenticated() &&
        resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.ownerUserId == request.auth.uid &&
        (request.resource.data.scope == "personal" || isWorkspaceMember(request.resource.data.workspaceId));

      // Allow delete only if authenticated user is the owner
      allow delete: if isAuthenticated() &&
        resource.data.ownerUserId == request.auth.uid;
    }

    // 7. Monthly Aggregates
    match /monthly_aggregates/{aggregateId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || isWorkspaceMember(resource.data.workspaceId)) &&
        (request.resource == null || isWorkspaceMember(request.resource.data.workspaceId));
    }
  }
}
