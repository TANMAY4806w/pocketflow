rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the authenticated user owns the document/profile
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: The workspace ID must equal the requesting user's own UID.
    // (Phase 1 single-user mode – no shared workspaces yet.)
    function isMyWorkspace(workspaceId) {
      return isAuthenticated() && workspaceId == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    // 1. Users Profile – only the owner can read/write their profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 2. Budgets – user can only access budgets belonging to their own workspace
    match /budgets/{budgetId} {
      allow read: if isAuthenticated() &&
        (resource == null || isMyWorkspace(resource.data.workspaceId));

      allow create: if isAuthenticated() &&
        isMyWorkspace(request.resource.data.workspaceId);

      allow update, delete: if isAuthenticated() &&
        resource != null && isMyWorkspace(resource.data.workspaceId);
    }

    // 3. Expenses / Transactions
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() &&
        (resource == null || isMyWorkspace(resource.data.workspaceId));

      allow create: if isAuthenticated() &&
        isMyWorkspace(request.resource.data.workspaceId);

      allow update, delete: if isAuthenticated() &&
        resource != null && isMyWorkspace(resource.data.workspaceId);
    }

    // 4. Todo Tasks
    match /todos/{todoId} {
      allow read: if isAuthenticated() &&
        (resource == null || isMyWorkspace(resource.data.workspaceId));

      allow create: if isAuthenticated() &&
        isMyWorkspace(request.resource.data.workspaceId);

      allow update, delete: if isAuthenticated() &&
        resource != null && isMyWorkspace(resource.data.workspaceId);
    }

    // 5. Savings Goals
    match /savingsGoals/{goalId} {
      allow read: if isAuthenticated() &&
        (resource == null || isMyWorkspace(resource.data.workspaceId));

      allow create: if isAuthenticated() &&
        isMyWorkspace(request.resource.data.workspaceId);

      allow update, delete: if isAuthenticated() &&
        resource != null && isMyWorkspace(resource.data.workspaceId);
    }

    // 6. Income Records
    match /income_records/{recordId} {
      allow read: if isAuthenticated() &&
        (resource == null || isMyWorkspace(resource.data.workspaceId));

      allow create: if isAuthenticated() &&
        isMyWorkspace(request.resource.data.workspaceId);

      allow update, delete: if isAuthenticated() &&
        resource != null && isMyWorkspace(resource.data.workspaceId);
    }

    // 7. Categories – allow authenticated users to read any category
    //    (system defaults have ownerUserId == "system", user ones have their uid)
    match /categories/{categoryId} {
      // Allow reading all categories to any authenticated user (needed for seeding)
      allow read: if isAuthenticated();

      // Allow create if user is setting themselves as the owner
      allow create: if isAuthenticated() &&
        (request.resource.data.ownerUserId == request.auth.uid ||
         request.resource.data.ownerUserId == "system");

      // Allow update/delete only if the user owns the category
      allow update, delete: if isAuthenticated() &&
        resource != null && resource.data.ownerUserId == request.auth.uid;
    }

    // 8. Monthly Aggregates (server-computed cache)
    match /monthly_aggregates/{aggregateId} {
      allow read: if isAuthenticated() &&
        (resource == null || isMyWorkspace(resource.data.workspaceId));

      allow create: if isAuthenticated() &&
        isMyWorkspace(request.resource.data.workspaceId);

      allow update, delete: if isAuthenticated() &&
        resource != null && isMyWorkspace(resource.data.workspaceId);
    }
  }
}
